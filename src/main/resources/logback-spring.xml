<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!--Console Appender-->
    <appender name="myConsoleAppender" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level [%class{0}:%line] - %msg%n</pattern>
        </encoder>
    </appender>


    <!-- File Appender -->
    <appender name="myFileAppender" class="ch.qos.logback.core.FileAppender">
        <file>app.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level [%class{0}:%line] - %msg%n</pattern>
        </encoder>
    </appender>


    <!-- Framework Logs -->
    <root level="INFO">
        <appender-ref ref="myConsoleAppender"/>
        <appender-ref ref="myFileAppender"/>
    </root>


    <!-- Application Logs -->
    <logger name="net.omprasad.Journal"
            level="INFO"
            additivity="false">
        <appender-ref ref="myFileAppender"/>
    </logger>

</configuration>
